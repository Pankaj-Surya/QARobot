PORT="3001"
FRONTEND_ORIGIN="http://localhost:3000"

# Neon/Postgres
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Upstash Vector
UPSTASH_VECTOR_REST_URL="https://example-vector.upstash.io"
UPSTASH_VECTOR_REST_TOKEN="upstash-vector-token"

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://example-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="upstash-redis-token"

# Upstash QStash
QSTASH_TOKEN="qstash-token"
QSTASH_CURRENT_SIGNING_KEY="qstash-current-signing-key"
QSTASH_NEXT_SIGNING_KEY="qstash-next-signing-key"

# Runner worker
RUNNER_MODE="disabled"
RUNNER_WORKER_URL="http://localhost:4001"
PAGE_INSPECTION_WORKER_URL="http://localhost:4001"
PUBLIC_BACKEND_URL="http://localhost:3001"
RUN_ARTIFACT_STORAGE_DRIVER="local"

# Optional Cloudflare R2. Leave blank for local document storage.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Generate a 32-byte base64 key for local use.
ENCRYPTION_KEY="base64-32-byte-encryption-key"
